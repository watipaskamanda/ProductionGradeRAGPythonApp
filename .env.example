# Environment Variables for RAG Application
# Copy to .env and fill with actual values

# Groq API Key (get from https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Database Password
DB_PASSWORD=your_secure_db_password_here

# Optional: Override default database settings
# DB_HOST=localhost
# DB_NAME=paymaart_test
# DB_USER=postgres
# DB_PORT=5432