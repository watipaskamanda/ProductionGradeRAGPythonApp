{
  "business_name": "PayMaart Financial Services",
  "domain_context": "financial_transactions",
  "business_language": {
    "primary_entity": "transactions",
    "currency": "MWK"
  },
  "business_definitions": {
    "sales": {
      "description": "Revenue from payment processing services",
      "sql_logic": "transaction_type IN ('pay_in', 'g2p_pay_in') AND type = 'credit'",
      "calculation": "SUM(transaction_amount::numeric)"
    },
    "expenses": {
      "description": "Operational costs and payouts",
      "sql_logic": "transaction_type IN ('payout_approved', 'settlement') AND type = 'debit'",
      "calculation": "SUM(transaction_amount::numeric)"
    },
    "float_transactions": {
      "description": "Liquidity management transactions",
      "sql_logic": "transaction_type IN ('float', 'excess_float')",
      "calculation": "SUM(transaction_amount::numeric)"
    },
    "high_value": {
      "description": "Transactions above 500,000 MWK",
      "sql_logic": "transaction_amount::numeric > 500000",
      "calculation": "COUNT(*) or SUM(transaction_amount::numeric)"
    },
    "recent": {
      "description": "Transactions in the last 30 days",
      "sql_logic": "created_at::double precision > EXTRACT(EPOCH FROM NOW() - INTERVAL '30 days')",
      "calculation": "COUNT(*) or SUM(transaction_amount::numeric)"
    }
  },
  "domain_terms": {
    "revenue": "transaction_type IN ('pay_in', 'g2p_pay_in') AND type = 'credit'",
    "costs": "transaction_type IN ('payout_approved', 'settlement') AND type = 'debit'",
    "high_value": "transaction_amount::numeric > 500000",
    "recent": "created_at::double precision > EXTRACT(EPOCH FROM NOW() - INTERVAL '30 days')"
  }
}